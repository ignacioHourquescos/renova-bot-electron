# OpenAI (para transcripción de audio, etc.)
OPENAI_API_KEY=sk-proj-...

# API de pedidos (flujo .pedido)
# Números permitidos para ingresar pedidos (separados por coma)
# PEDIDOS_WHITELIST_NUMBERS=5491140565047,5491165106333
# URL base del sistema de gestión de pedidos
PEDIDOS_BOT_BASE_URL=http://localhost:4000
# Path del endpoint (por defecto /api/pedidos-bot)
# PEDIDOS_BOT_API_PATH=/api/pedidos-bot
# Opcional: API key para autenticación (header X-API-Key)
# PEDIDOS_BOT_API_KEY=tu_api_key_secreta

# Firebase Storage (para guardar imágenes y audios y que la app de pedidos pueda verlos/escucharlos)
# Ruta al JSON de la cuenta de servicio (descargar desde Firebase Console > Configuración del proyecto)
GOOGLE_APPLICATION_CREDENTIALS=firebase-service-account.json
# Nombre del bucket (ej: mi-proyecto.appspot.com o mi-proyecto.firebasestorage.app)
FIREBASE_STORAGE_BUCKET=renova-errores-2
